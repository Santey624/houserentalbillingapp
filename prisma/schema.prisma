// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Role {
  LANDLORD
  TENANT
}

enum TenancyStatus {
  PENDING
  ACTIVE
  ENDED
}

enum JoinRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum InvoiceStatus {
  UNPAID
  PAYMENT_SUBMITTED
  PAID
  OVERDUE
}

enum PaymentMethod {
  ESEWA
  KHALTI
  BANK_TRANSFER
  CASH
}

enum PaymentStatus {
  PENDING_VERIFICATION
  VERIFIED
  REJECTED
}

enum MaintenanceStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

// ─── Auth.js Models ───────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          Role      @default(TENANT)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  landlord      Landlord?
  tenant        Tenant?
  notifications Notification[]

  verificationTokens VerificationToken[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  type      String   // "email_verify" | "password_reset"
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Domain Models ────────────────────────────────────────────────────────────

model Landlord {
  id              String   @id @default(cuid())
  userId          String   @unique
  displayName     String
  address         String   @default("")
  contact         String   @default("")
  electricityRate Float    @default(17.0)
  paymentDueDay   Int      @default(2)
  bankDetails     String?  @db.Text
  qrImageUrl      String?
  onboardingDone  Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  buildings Building[]
}

model Building {
  id           String   @id @default(cuid())
  landlordId   String
  name         String
  address      String
  contact      String   @default("")
  isOpen       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  landlord     Landlord       @relation(fields: [landlordId], references: [id], onDelete: Cascade)
  units        Unit[]
  joinRequests JoinRequest[]
}

model Unit {
  id         String   @id @default(cuid())
  buildingId String
  unitNumber String
  floor      String?
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  building     Building      @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  tenancies    Tenancy[]
  joinRequests JoinRequest[]
  invoices     Invoice[]

  @@unique([buildingId, unitNumber])
}

model Tenant {
  id          String   @id @default(cuid())
  userId      String   @unique
  displayName String
  contact     String   @default("")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenancies    Tenancy[]
  joinRequests JoinRequest[]
  maintenanceRequests MaintenanceRequest[]
}

model Tenancy {
  id        String        @id @default(cuid())
  tenantId  String
  unitId    String
  status    TenancyStatus @default(PENDING)
  startDate DateTime      @default(now())
  endDate   DateTime?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  unit     Unit      @relation(fields: [unitId], references: [id], onDelete: Cascade)
  invoices Invoice[]
}

model JoinRequest {
  id         String            @id @default(cuid())
  tenantId   String
  buildingId String
  unitId     String?
  status     JoinRequestStatus @default(PENDING)
  note       String?
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  building Building @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  unit     Unit?    @relation(fields: [unitId], references: [id])
}

model Invoice {
  id            String        @id @default(cuid())
  invoiceNumber String        @unique
  tenancyId     String
  unitId        String
  tenantName    String
  nepaliMonth   String
  nepaliYear    String
  invoiceDate   String
  dueDate       String?
  rentCost      Float
  serviceCharge Float         @default(0)
  totalElec     Float         @default(0)
  grandTotal    Float
  status        InvoiceStatus @default(UNPAID)
  notes         String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  tenancy   Tenancy          @relation(fields: [tenancyId], references: [id], onDelete: Cascade)
  unit      Unit             @relation(fields: [unitId], references: [id])
  lineItems InvoiceLineItem[]
  payments  Payment[]
}

model InvoiceLineItem {
  id          String  @id @default(cuid())
  invoiceId   String
  description String
  units       Float?
  rate        Float?
  amount      Float
  sortOrder   Int     @default(0)

  invoice      Invoice       @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  meterReading MeterReading?
}

model MeterReading {
  id         String @id @default(cuid())
  lineItemId String @unique
  meterName  String
  prevReading Float
  currReading Float
  consumed   Float
  rate       Float

  lineItem InvoiceLineItem @relation(fields: [lineItemId], references: [id], onDelete: Cascade)
}

model Payment {
  id            String        @id @default(cuid())
  invoiceId     String
  method        PaymentMethod
  referenceNum  String?
  proofImageUrl String?
  amount        Float
  status        PaymentStatus @default(PENDING_VERIFICATION)
  verifiedBy    String?
  verifiedAt    DateTime?
  rejectionNote String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
}

model MaintenanceRequest {
  id          String            @id @default(cuid())
  tenantId    String
  title       String
  description String            @db.Text
  photoUrl    String?
  status      MaintenanceStatus @default(OPEN)
  landlordNote String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  resolvedAt  DateTime?

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  message   String
  linkUrl   String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
