# Runtime database connection (pooled) and migration connection (direct)
DATABASE_URL=postgresql://user:password@host/database?sslmode=require
DIRECT_URL=postgresql://user:password@host/database?sslmode=require

# Auth.js
AUTH_SECRET=replace-with-at-least-32-random-bytes
AUTH_URL=http://localhost:3000

# Email (RESEND_FROM must use a domain verified in Resend; resend.dev only delivers to the account owner)
RESEND_API_KEY=re_replace_me
RESEND_FROM=noreply@your-verified-domain.com

# Vercel Blob
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_replace_me
